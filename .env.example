# ──────────────────────────────────────────────────────────────
# DriveLoc – Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE PAS committer le fichier .env (voir .gitignore)
# ──────────────────────────────────────────────────────────────

# URL publique de l'application (sans slash final)
# Sur Render  : https://<votre-service>.onrender.com
# En local    : http://localhost:8080
APP_URL=https://your-service.onrender.com

# Environnement applicatif
APP_ENV=production

# Initialisation automatique de la base si aucune table n'existe.
# A activer a true uniquement pour le premier bootstrap.
AUTO_INSTALL_DB=false

# ── Base de données ─────────────────────────────────────────
# Sur Render : renseigner directement les variables DB_* dans le dashboard.
# Avec une DB externe, utiliser l'hôte, port, nom, user, mot de passe fournis.

DB_HOST=localhost
DB_PORT=3306
DB_NAME=driveloc
DB_USER=driveloc
DB_PASS=driveloc
