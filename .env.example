# ──────────────────────────────────────────────────────────────
# DriveLoc – Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# NE PAS committer le fichier .env (voir .gitignore)
# ──────────────────────────────────────────────────────────────

# URL publique de l'application (sans slash final)
# Sur Render  : https://<votre-service>.onrender.com
# En local    : http://localhost:8080
# Sur Caddy    : https://votre-domaine (root /var/www/driveloc)
APP_URL=https://driveloc.mateomoreau.com

# Environnement applicatif
APP_ENV=production

# Initialisation automatique de la base si aucune table n'existe.
# A activer a true uniquement pour le premier bootstrap, puis remettre a false.
AUTO_INSTALL_DB=false

# Debug bootstrap DB (logs erreurs bootstrap dans les logs serveur)
# false en production pour eviter le bruit de logs
LOG_BOOTSTRAP_ERRORS=false

# Afficher les erreurs PHP directement dans la page (debug temporaire)
# Mettre a true uniquement le temps de diagnostiquer une erreur 500
DEBUG_DISPLAY_ERRORS=false

# ── Base de données ─────────────────────────────────────────
# Sur Render : renseigner directement les variables DB_* dans le dashboard.
# Avec une DB externe, utiliser l'hôte, port, nom, user, mot de passe fournis.

DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASS=
